{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "*.txt",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff",
        "Strict-Transport-Security": "max-age=63072000; includeSubDomains; preload",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "geolocation=(), microphone=(), camera=()",
        "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://xrljfmrsrxyepdsysfan.supabase.co https://www.google-analytics.com; connect-src 'self' https://xrljfmrsrxyepdsysfan.supabase.co https://api.stripe.com https://www.google-analytics.com https://*.paypal.com https://*.paypalobjects.com https://nowpayments.io https://*.nowpayments.io; frame-src https://js.stripe.com https://*.paypal.com; object-src 'none'; base-uri 'self';"
      },
     "continue": true
    },
    {
      "src": "/api/checkout",
      "dest": "/api/checkout.js"
    },
    {
      "src": "/api/crypto-checkout",
      "dest": "/api/crypto-checkout.js"
    },
    {
      "src": "/api/commandes",
      "dest": "/api/commandes.js"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/paypal-confirmation",
      "dest": "/api/paypal-confirmation.js"
    },
    {
      "src": "/api/webhook-crypto",
      "dest": "/api/webhook-crypto.js"
    },
    {
      "src": "/api/paypal-livraison",
      "dest": "/api/paypal-livraison.js"
    },
    {
      "src": "/api/gratuit",
      "dest": "/api/gratuit.js"
    },
    {
      "src": "/api/admin-login",
      "dest": "/api/admin-login.js"
    },
    {
      "src": "/api/admin-formations",
      "dest": "/api/admin-formations.js"
    },
    {
      "src": "/api/admin-content",
      "dest": "/api/admin-content.js"
    },
    {
      "src": "/api/telegram-webhook",
      "dest": "/api/telegram-webhook.js"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/api/sitemap.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/formation/([^/]+)",
      "dest": "/formation.html?slug=$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
